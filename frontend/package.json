{
  "name": "frontend-svelte-shadcn",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "mobile:build": "pnpm run build && npx cap sync android",
    "mobile:open": "npx cap open android",
    "mobile:apk": "pnpm run mobile:build && ./android/gradlew -p android assembleDebug",
    "mobile:release": "pnpm run mobile:build && ./android/gradlew -p android assembleRelease",
    "lint": "eslint .",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.3",
    "@capacitor/cli": "^7.4.3",
    "@capacitor/core": "^7.4.3",
    "@fontsource-variable/geist": "^5.2.9",
    "@lucide/svelte": "^1.0.1",
    "axios": "^1.11.0",
    "clsx": "^2.1.1",
    "katex": "^0.17.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.2.8",
    "@internationalized/date": "^3.12.2",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^24.12.3",
    "bits-ui": "^2.18.1",
    "eslint": "^10.3.0",
    "eslint-plugin-svelte": "^3.12.4",
    "globals": "^17.6.0",
    "jsdom": "^26.1.0",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.8",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.46.3",
    "vite": "^8.0.12",
    "vitest": "^3.2.4"
  }
}
